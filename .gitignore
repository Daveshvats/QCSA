# =============================================================================
# LoomScan .gitignore — keeps build artifacts, caches, and runtime files
# out of the GitHub repo. Source code, compiled VS Code extension, and
# rule packs ARE committed.
# =============================================================================

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── LoomScan Runtime Artifacts ──────────────────────────────────────────────
# These are generated when LoomScan runs — never commit them
.loomscan-cache/
.loomscan-audit.log
.loomscan-issues.db
.loomscan-fp-learning.json
.loomscan-hotspots.json
.loomscan-hotspot-audit.log
.loomscan-reports/
.loomscan-fixes/
loomscan-dashboard.html
loomscan.sarif

# ── Legacy STCA Runtime Artifacts (pre-rename) ─────────────────────────────
# In case any old files linger from before the stca→loomscan rename
.stca-cache/
.stca-audit.log
.stca-issues.db
.stca-fp-learning.json
.stca-hotspots.json
.stca-hotspot-audit.log
.stca-reports/
.stca-fixes/

# ── Test / Coverage Cache ──────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ── IDE ────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Editor Plugins — Build Artifacts Only ──────────────────────────────────
# NOTE: editor/vscode-loomscan/out/ IS committed (compiled extension.js
#       is needed for CI tests). Only node_modules and .vscode-test are ignored.
editor/vscode-loomscan/node_modules/
editor/vscode-loomscan/.vscode-test/
editor/vscode-loomscan/*.vsix
editor/intellij-loomscan/build/
editor/intellij-loomscan/.gradle/
editor/intellij-loomscan/build/distributions/

# ── Rust Core — Build Artifacts ────────────────────────────────────────────
rust-core/target/
rust-core/Cargo.lock

# ── OS Files ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Internal Worklog (not for users) ───────────────────────────────────────
worklog.md

# ── Examples — Runtime Artifacts ───────────────────────────────────────────
examples/sample-python-repo/.loomscan-*
examples/sample-python-repo/.stca-*
examples/sample-python-repo/loomscan-dashboard.html
